<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.demo.app.web.login.repository.mapper.LoginMapper">

  <!-- 조회하기: email로 조회 -->
  <select id="selectOneByEmail" resultType="org.demo.app.web.member.domain.Member">
    select email,
           password
    from member
    where email = #{email}
  </select>

</mapper>
